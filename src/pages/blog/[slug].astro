---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await Astro.glob('./*.md');
  return posts.map(post => ({
    params: { slug: post.frontmatter.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { title, date, author, description, canonicalUrl } = post.frontmatter;

function formatDate(dateStr) {
  const [y, m, d] = dateStr.split('-');
  const months = ['janeiro', 'fevereiro', 'março', 'abril', 'maio', 'junho', 
                  'julho', 'agosto', 'setembro', 'outubro', 'novembro', 'dezembro'];
  return `${parseInt(d)} de ${months[parseInt(m)-1]} de ${y}`;
}
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>
  <article>
    <header style="margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid #eee;">
      <span style="font-size: 0.9rem; color: var(--color-text-light);">
        {formatDate(date)} · {author}
      </span>
      <h1 style="margin-top: 0.5rem; font-family: var(--font-heading); font-size: 2rem; line-height: 1.3;">
        {title}
      </h1>
    </header>
    
    <div class="post-content" style="font-size: 1.05rem;">
      <slot />
    </div>
    
    <footer style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid #eee;">
      <p style="font-size: 0.9rem; color: var(--color-text-light);">
        Posted by <strong>{author}</strong>
      </p>
      <a href="/blog" style="color: var(--color-primary); font-size: 0.9rem;">
        ← Voltar ao Blog
      </a>
    </footer>
  </article>
</Layout>

<style>
  .post-content :global(p) { margin-bottom: 1.25rem; }
  .post-content :global(h2) { 
    font-family: var(--font-heading); 
    margin: 2rem 0 1rem; 
    font-size: 1.5rem;
  }
  .post-content :global(h3) { 
    font-family: var(--font-heading); 
    margin: 1.5rem 0 0.75rem; 
    font-size: 1.25rem;
  }
  .post-content :global(a) { color: var(--color-primary); }
  .post-content :global(img) { 
    max-width: 100%; 
    height: auto; 
    margin: 1rem 0;
    border-radius: 4px;
  }
  .post-content :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-text-light);
  }
  .post-content :global(ul), .post-content :global(ol) {
    margin: 1rem 0 1rem 1.5rem;
  }
  .post-content :global(li) { margin-bottom: 0.5rem; }
  .post-content :global(strong) { font-weight: 600; }
  .post-content :global(em) { font-style: italic; }
  .post-content :global(pre) {
    background: var(--color-bg-alt);
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
    font-size: 0.9rem;
    margin: 1.5rem 0;
  }
  .post-content :global(code) {
    font-family: monospace;
    background: var(--color-bg-alt);
    padding: 0.2rem 0.4rem;
    border-radius: 3px;
    font-size: 0.9em;
  }
</style>
