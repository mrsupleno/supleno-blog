---
export interface Props {
  title?: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Artigos sobre desenvolvimento humano, PNL, hipnose e terapia" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Source+Sans+Pro:wght@300;400;600&display=swap" rel="stylesheet" />
  <title>{title ? `${title} | Supleno` : 'Supleno'}</title>
  <style>
    :root {
      --primary: #2c5f2d;
      --secondary: #97bc62;
      --text: #1a1a1a;
      --text-light: #555;
      --text-lighter: #888;
      --bg: #fff;
      --bg-alt: #f9f9f7;
      --border: #e8e8e4;
      --serif: 'Playfair Display', Georgia, serif;
      --sans: 'Source Sans Pro', -apple-system, BlinkMacSystemFont, sans-serif;
      --max: 720px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--sans); color: var(--text); line-height: 1.7; background: var(--bg); font-size: 18px; }

    header { background: var(--primary); padding: 1.25rem 1rem; position: sticky; top: 0; z-index: 100; }
    .container { max-width: 960px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
    header a { color: #fff; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
    header a:hover { opacity: 0.8; }
    .logo { font-family: var(--serif); font-size: 1.5rem !important; font-weight: 700; }
    nav a { margin-left: 1.5rem; }

    main { max-width: var(--max); margin: 0 auto; padding: 2rem 1rem 4rem; }

    footer { background: var(--bg-alt); border-top: 1px solid var(--border); padding: 2rem 1rem; text-align: center; color: var(--text-lighter); font-size: 0.88rem; }
    footer a { color: var(--primary); text-decoration: none; }

    /* ARTICLE TYPOGRAPHY */
    .article-content h1 {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 1.5rem;
      color: var(--text);
    }
    .article-content h2 {
      font-family: var(--serif);
      font-size: 1.55rem;
      font-weight: 600;
      color: var(--text);
      margin: 2.5rem 0 0.8rem;
      line-height: 1.3;
    }
    .article-content h3 {
      font-family: var(--serif);
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--text);
      margin: 2rem 0 0.6rem;
    }
    .article-content p {
      margin-bottom: 1.6em;
      font-size: 1.08rem;
      line-height: 1.85;
    }
    .article-content blockquote {
      border-left: 4px solid var(--primary);
      margin: 2em 0;
      padding: 1.2em 1.5em;
      background: var(--bg-alt);
      font-family: var(--serif);
      font-size: 1.15rem;
      font-style: italic;
      color: var(--text-light);
    }
    .article-content blockquote p { margin-bottom: 0; }
    .article-content img {
      max-width: 100%;
      height: auto;
      border-radius: 4px;
      margin: 2em auto;
      display: block;
    }
    .article-content a { color: var(--primary); }
    .article-content ul, .article-content ol { margin: 1.5em 0; padding-left: 1.5em; }
    .article-content li { margin-bottom: 0.5em; font-size: 1.05rem; }
    .article-content strong { font-weight: 600; }
    .article-content em { font-style: italic; }

    /* AUTHOR BOX */
    .author-box {
      max-width: var(--max);
      margin: 0 auto;
      padding: 0 1rem 4rem;
    }
    .author-card {
      background: var(--bg-alt);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.5rem;
      display: flex;
      gap: 1.25rem;
      align-items: flex-start;
    }
    .author-avatar {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: var(--primary);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--serif);
      font-size: 1.4rem;
      font-weight: 700;
      flex-shrink: 0;
    }
    .author-info h4 { font-family: var(--serif); font-size: 1.05rem; margin-bottom: 0.4em; }
    .author-info p { font-size: 0.88rem; color: var(--text-light); line-height: 1.6; }

    /* POST LIST on index */
    .post-list article {
      margin-bottom: 2.5rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--border);
    }
    .post-list h2 a { color: var(--primary); text-decoration: none; font-family: var(--serif); }
    .post-list h2 a:hover { text-decoration: underline; }
    .post-meta { font-size: 0.85rem; color: var(--text-light); margin-bottom: 0.5rem; }

    @media (max-width: 600px) {
      .container { flex-direction: column; gap: 1rem; text-align: center; }
      nav a { margin: 0 0.6rem; }
    }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <a href="/" class="logo">Supleno</a>
      <nav>
        <a href="/">Artigos</a>
        <a href="https://supleno.com" target="_blank">Site Principal ↗</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <p>© 2026 Supleno — <a href="https://supleno.com">supleno.com</a></p>
  </footer>
</body>
</html>
