---
export interface Props {
  title?: string;
  description?: string;
  date?: string;
  author?: string;
  canonicalUrl?: string;
}
const { title, description, date, author, canonicalUrl } = Astro.props;
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={`${title} | Supleno`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="article" />
  <meta property="og:site_name" content="Supleno" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={`${title} | Supleno`} />
  <meta name="twitter:description" content={description} />
  <title>{title} | Supleno</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Source+Sans+Pro:wght@300;400;600&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --primary: #2c5f2d;
      --text: #1a1a1a;
      --text-light: #555;
      --text-lighter: #888;
      --bg: #fff;
      --bg-alt: #f9f9f7;
      --border: #e8e8e4;
      --serif: 'Playfair Display', Georgia, serif;
      --sans: 'Source Sans Pro', -apple-system, BlinkMacSystemFont, sans-serif;
      --max: 720px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--sans); color: var(--text); line-height: 1.7; background: var(--bg); font-size: 18px; }
    a { color: var(--primary); }

    header { background: var(--primary); padding: 1.25rem 1rem; position: sticky; top: 0; z-index: 100; }
    .hdr-inner { max-width: 960px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
    header a { color: #fff; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
    header a:hover { opacity: 0.8; }
    .logo { font-family: var(--serif); font-size: 1.5rem !important; font-weight: 700; }
    nav a { margin-left: 1.5rem; }

    main { max-width: var(--max); margin: 0 auto; padding: 2rem 1rem 4rem; }

    /* Article content styling */
    .article-header { max-width: var(--max); margin: 0 auto; padding: 3.5rem 1rem 2.5rem; text-align: center; border-bottom: 1px solid var(--border); }
    .article-category { display: inline-block; font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--primary); margin-bottom: 1rem; }
    .article-title { font-family: var(--serif); font-size: clamp(1.8rem, 5vw, 2.8rem); font-weight: 700; line-height: 1.2; color: var(--text); margin-bottom: 1.25rem; }
    .article-meta { display: flex; align-items: center; justify-content: center; gap: 0.75rem; font-size: 0.9rem; color: var(--text-light); flex-wrap: wrap; }
    .article-meta .author { font-weight: 600; color: var(--text); }
    .article-meta .sep { color: var(--border); }
    .article-meta .date { color: var(--text-lighter); }

    .article-body { max-width: var(--max); margin: 0 auto; padding: 2.5rem 1rem 0; }
    .article-body p { margin-bottom: 1.6em; font-size: 1.08rem; line-height: 1.85; }
    .article-body h2 { font-family: var(--serif); font-size: 1.55rem; font-weight: 600; color: var(--text); margin: 2.5em 0 0.8em; line-height: 1.3; }
    .article-body h3 { font-family: var(--serif); font-size: 1.25rem; font-weight: 600; color: var(--text); margin: 2em 0 0.6em; }
    .article-body blockquote { border-left: 4px solid var(--primary); margin: 2em 0; padding: 1.2em 1.5em; background: var(--bg-alt); font-family: var(--serif); font-size: 1.15rem; font-style: italic; color: var(--text-light); }
    .article-body img { max-width: 100%; height: auto; border-radius: 4px; margin: 2em auto; display: block; }
    .article-body ul, .article-body ol { margin: 1.5em 0; padding-left: 1.5em; }
    .article-body li { margin-bottom: 0.5em; font-size: 1.05rem; }
    .article-body strong { font-weight: 600; }

    .author-box { max-width: var(--max); margin: 0 auto; padding: 0 1rem 4rem; }
    .author-card { background: var(--bg-alt); border: 1px solid var(--border); border-radius: 8px; padding: 1.5rem; display: flex; gap: 1.25rem; align-items: flex-start; }
    .author-avatar { width: 64px; height: 64px; border-radius: 50%; background: var(--primary); color: #fff; display: flex; align-items: center; justify-content: center; font-family: var(--serif); font-size: 1.4rem; font-weight: 700; flex-shrink: 0; }
    .author-info h4 { font-family: var(--serif); font-size: 1.05rem; margin-bottom: 0.4em; }
    .author-info p { font-size: 0.88rem; color: var(--text-light); line-height: 1.6; }

    footer { background: var(--bg-alt); border-top: 1px solid var(--border); padding: 2rem 1rem; text-align: center; color: var(--text-lighter); font-size: 0.88rem; }
    footer a { color: var(--primary); text-decoration: none; }

    /* Blog listing page */
    .blog-title { font-family: var(--serif); font-size: 2.2rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--text); }
    .blog-subtitle { color: var(--text-light); margin-bottom: 2.5rem; font-size: 1.05rem; }
    .post-item { margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); }
    .post-meta { font-size: 0.85rem; color: var(--text-light); display: block; margin-bottom: 0.5rem; }
    .post-title { font-family: var(--serif); font-size: 1.35rem; margin: 0.5rem 0; }
    .post-title a { color: var(--primary); text-decoration: none; }
    .post-title a:hover { text-decoration: underline; }
    .post-desc { color: var(--text-light); font-size: 0.95rem; line-height: 1.6; margin-bottom: 0.75rem; }
    .post-link { color: var(--primary); font-size: 0.9rem; font-weight: 600; text-decoration: none; }

    @media (max-width: 600px) {
      .hdr-inner { flex-direction: column; gap: 1rem; text-align: center; }
      nav a { margin: 0 0.6rem; }
      .article-title { font-size: 1.8rem; }
      .article-meta { flex-direction: column; gap: 0.3rem; }
      .author-card { flex-direction: column; }
    }
  </style>
</head>
<body>
  <header>
    <div class="hdr-inner">
      <a href="/" class="logo">Supleno</a>
      <nav>
        <a href="/">Artigos</a>
        <a href="https://supleno.com" target="_blank">Site Principal ↗</a>
      </nav>
    </div>
  </header>
  <slot />
  <footer>
    <p>© 2026 Supleno — <a href="https://supleno.com">supleno.com</a></p>
  </footer>
</body>
</html>
