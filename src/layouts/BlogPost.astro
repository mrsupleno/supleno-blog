---
export interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  date?: string;
  author?: string;
  image?: string;
  content?: string;
}

const { title, description, canonicalUrl, date, author, image, content = '' } = Astro.props;

function formatDate(dateStr) {
  if (!dateStr) return '';
  const [y, m, d] = dateStr.split('-');
  const months = ['janeiro', 'fevereiro', 'março', 'abril', 'maio', 'junho', 
                  'julho', 'agosto', 'setembro', 'outubro', 'novembro', 'dezembro'];
  return d.startsWith('0') ? `${parseInt(d)} de ${months[parseInt(m)-1]} de ${y}` : `${parseInt(d)} de ${months[parseInt(m)-1]} de ${y}`;
}

const formattedDate = formatDate(date);
const authorInitials = author ? author.split(' ').map(n => n[0]).slice(0, 2).join('') : '';
const siteName = 'Supleno';
const siteUrl = 'https://blog.supleno.com';
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
  <meta property="og:type" content="article" />
  <meta property="og:title" content={`${title} | ${siteName}`} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content={siteName} />
  {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={`${title} | ${siteName}`} />
  <meta name="twitter:description" content={description} />
  <title>{title} | {siteName}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Source+Sans+Pro:wght@300;400;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --primary: #2c5f2d;
      --primary-dark: #1e4a1f;
      --secondary: #97bc62;
      --accent: #f5a623;
      --text: #1a1a1a;
      --text-light: #555;
      --text-lighter: #888;
      --bg: #fff;
      --bg-alt: #f9f9f7;
      --border: #e8e8e4;
      --serif: 'Playfair Display', Georgia, serif;
      --sans: 'Source Sans Pro', -apple-system, BlinkMacSystemFont, sans-serif;
      --max: 720px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--sans); color: var(--text); line-height: 1.7; background: var(--bg); font-size: 18px; }
    header.site-hdr { background: var(--primary); padding: 1.25rem 1rem; position: sticky; top: 0; z-index: 100; }
    .hdr-inner { max-width: 960px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
    header a { color: #fff; text-decoration: none; font-weight: 600; font-size: 0.95rem; transition: opacity 0.2s; }
    header a:hover { opacity: 0.8; }
    .logo { font-family: var(--serif); font-size: 1.5rem !important; font-weight: 700; }
    header nav a { margin-left: 1.5rem; }

    .art-hdr { max-width: var(--max); margin: 0 auto; padding: 3.5rem 1rem 2.5rem; text-align: center; border-bottom: 1px solid var(--border); }
    .art-cat { display: inline-block; font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--primary); margin-bottom: 1rem; }
    .art-title { font-family: var(--serif); font-size: clamp(1.8rem, 5vw, 2.8rem); font-weight: 700; line-height: 1.2; color: var(--text); margin-bottom: 1.25rem; }
    .art-meta { display: flex; align-items: center; justify-content: center; gap: 0.75rem; font-size: 0.9rem; color: var(--text-light); flex-wrap: wrap; }
    .art-meta .by { font-weight: 600; color: var(--text); }
    .art-meta .sep { color: var(--border); }
    .art-meta .dt { color: var(--text-lighter); }

    .art-body { max-width: var(--max); margin: 0 auto; padding: 2.5rem 1rem 4rem; }

    .art-body p { margin-bottom: 1.6em; font-size: 1.08rem; line-height: 1.85; color: var(--text); }
    .art-body h2 { font-family: var(--serif); font-size: 1.55rem; font-weight: 600; color: var(--text); margin: 2.5em 0 0.8em; line-height: 1.3; }
    .art-body h3 { font-family: var(--serif); font-size: 1.25rem; font-weight: 600; color: var(--text); margin: 2em 0 0.6em; }
    .art-body blockquote { border-left: 4px solid var(--primary); margin: 2em 0; padding: 1.2em 1.5em; background: var(--bg-alt); font-family: var(--serif); font-size: 1.15rem; font-style: italic; color: var(--text-light); }
    .art-body blockquote p { margin-bottom: 0; font-size: 1.15rem; }
    .art-body img { max-width: 100%; height: auto; border-radius: 4px; margin: 2em auto; display: block; }
    .art-body a { color: var(--primary); }
    .art-body ul, .art-body ol { margin: 1.5em 0; padding-left: 1.5em; }
    .art-body li { margin-bottom: 0.5em; font-size: 1.05rem; line-height: 1.7; }
    .art-body strong { font-weight: 600; }
    .art-body em { font-style: italic; }

    .auth-box { max-width: var(--max); margin: 0 auto; padding: 0 1rem 4rem; }
    .auth-card { background: var(--bg-alt); border: 1px solid var(--border); border-radius: 8px; padding: 1.5rem; display: flex; gap: 1.25rem; align-items: flex-start; }
    .auth-av { width: 64px; height: 64px; border-radius: 50%; background: var(--primary); color: #fff; display: flex; align-items: center; justify-content: center; font-family: var(--serif); font-size: 1.4rem; font-weight: 700; flex-shrink: 0; }
    .auth-info h4 { font-family: var(--serif); font-size: 1.05rem; margin-bottom: 0.4em; }
    .auth-info p { font-size: 0.88rem; color: var(--text-light); line-height: 1.6; }

    footer { background: var(--bg-alt); border-top: 1px solid var(--border); padding: 2rem 1rem; text-align: center; color: var(--text-lighter); font-size: 0.88rem; }
    footer a { color: var(--primary); text-decoration: none; }
    footer a:hover { text-decoration: underline; }

    @media (max-width: 600px) {
      .hdr-inner { flex-direction: column; gap: 1rem; text-align: center; }
      nav a { margin: 0 0.6rem; }
      .art-title { font-size: 1.8rem; }
      .art-meta { flex-direction: column; gap: 0.3rem; }
      .auth-card { flex-direction: column; }
    }
  </style>
</head>
<body>
  <header class="site-hdr">
    <div class="hdr-inner">
      <a href="/" class="logo">Supleno</a>
      <nav>
        <a href="/">Artigos</a>
        <a href="https://supleno.com" target="_blank">Site Principal ↗</a>
      </nav>
    </div>
  </header>

  <div class="art-hdr">
    <div class="art-cat">Desenvolvimento Humano</div>
    <h1 class="art-title">{title}</h1>
    <div class="art-meta">
      {author && <span class="by">{author}</span>}
      {author && date && <span class="sep">·</span>}
      {date && <span class="dt">{formattedDate}</span>}
    </div>
  </div>

  <div class="art-body" id="article-content"></div>

  {author && (
    <div class="auth-box">
      <div class="auth-card">
        <div class="auth-av">{authorInitials}</div>
        <div class="auth-info">
          <h4>{author}</h4>
          <p>Terapeuta e desenvolvedor humano. Especialista em PNL, Hipnose Ericksoniana e Coaching Sistêmico.</p>
        </div>
      </div>
    </div>
  )}

  <footer>
    <p>© 2026 Supleno — <a href="https://supleno.com">supleno.com</a></p>
  </footer>

  <script define:vars={{ content }}>
    document.getElementById('article-content').innerHTML = content;
  </script>
</body>
</html>
